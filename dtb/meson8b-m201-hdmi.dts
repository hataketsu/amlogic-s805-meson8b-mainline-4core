/dts-v1/;

/ {
	#address-cells = <0x01>;
	#size-cells = <0x01>;
	interrupt-parent = <0x01>;
	model = "TRONFY MXQ S805";
	compatible = "tronfy,mxq", "amlogic,meson8b";

	iio-hwmon {
		compatible = "iio-hwmon";
		io-channels = <0x02 0x08>;
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;

		bus@c1100000 {
			compatible = "simple-bus";
			reg = <0xc1100000 0x200000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0xc1100000 0x200000>;

			system-controller@4000 {
				compatible = "amlogic,meson-hhi-sysctrl", "simple-mfd", "syscon";
				reg = <0x4000 0x400>;
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				ranges = <0x00 0x4000 0x400>;
				phandle = <0x0b>;

				video-dac@2f4 {
					compatible = "amlogic,meson8b-cvbs-dac", "amlogic,meson-cvbs-dac";
					reg = <0x2f4 0x08>;
					#phy-cells = <0x00>;
					status = "disabled";
					clocks = <0x03 0xab>;
					nvmem-cells = <0x04>;
					nvmem-cell-names = "cvbs_trimming";
					phandle = <0x30>;
				};

				clock-controller@0 {
					compatible = "amlogic,meson8b-clkc";
					reg = <0x00 0x39c>;
					clocks = <0x05 0x06 0x01>;
					clock-names = "xtal", "ddr_pll";
					#clock-cells = <0x01>;
					#reset-cells = <0x01>;
					phandle = <0x03>;
				};

				power-controller@100 {
					compatible = "amlogic,meson8b-pwrc";
					reg = <0x100 0x10>;
					#power-domain-cells = <0x01>;
					amlogic,ao-sysctrl = <0x07>;
					resets = <0x08 0x42 0x08 0x43 0x08 0x4b 0x08 0x4f 0x08 0x86 0x08 0x87 0x08 0x89 0x08 0x8d 0x08 0x05 0x08 0x0a 0x08 0x85>;
					reset-names = "dblk", "pic_dc", "hdmi_apb", "hdmi_system", "venci", "vencp", "vdac", "vencl", "viu", "venc", "rdma";
					clocks = <0x03 0xbe>;
					clock-names = "vpu";
					assigned-clocks = <0x03 0xbe>;
					assigned-clock-rates = <0xadb4789>;
					phandle = <0x19>;
				};

				hdmi-phy@3a0 {
					compatible = "amlogic,meson8b-hdmi-tx-phy", "amlogic,meson8-hdmi-tx-phy";
					clocks = <0x03 0x84>;
					reg = <0x3a0 0x0c>;
					#phy-cells = <0x00>;
					phandle = <0x2a>;
				};
			};

			audio-controller@5400 {
				compatible = "amlogic,aiu-meson8b", "amlogic,aiu";
				#sound-dai-cells = <0x02>;
				sound-name-prefix = "AIU";
				reg = <0x5400 0x2ac>;
				interrupts = <0x00 0x30 0x01 0x00 0x32 0x01>;
				interrupt-names = "i2s", "spdif";
				status = "okay";
				clocks = <0x03 0x26 0x03 0x28 0x03 0x50 0x03 0xd1 0x03 0x2c 0x03 0x27 0x03 0x51 0x03 0xd4 0x03 0xd5>;
				clock-names = "pclk", "i2s_pclk", "i2s_aoclk", "i2s_mclk", "i2s_mixer", "spdif_pclk", "spdif_aoclk", "spdif_mclk", "spdif_mclk_sel";
				resets = <0x08 0x06>;
				phandle = <0x35>;
			};

			assist@7c00 {
				compatible = "syscon";
				reg = <0x7c00 0x200>;
			};

			rng@8100 {
				compatible = "amlogic,meson-rng";
				reg = <0x8100 0x08>;
				clocks = <0x03 0x19>;
				clock-names = "core";
			};

			serial@84c0 {
				compatible = "amlogic,meson8b-uart";
				reg = <0x84c0 0x18>;
				interrupts = <0x00 0x1a 0x01>;
				fifo-size = <0x80>;
				status = "disabled";
				clocks = <0x05 0x03 0x1a 0x03 0x0a>;
				clock-names = "xtal", "pclk", "baud";
			};

			serial@84dc {
				compatible = "amlogic,meson8b-uart";
				reg = <0x84dc 0x18>;
				interrupts = <0x00 0x4b 0x01>;
				status = "disabled";
				clocks = <0x05 0x03 0x30 0x03 0x0a>;
				clock-names = "xtal", "pclk", "baud";
			};

			i2c@8500 {
				compatible = "amlogic,meson6-i2c";
				reg = <0x8500 0x20>;
				interrupts = <0x00 0x15 0x01>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				status = "disabled";
				clocks = <0x03 0x16>;
			};

			pwm@8550 {
				compatible = "amlogic,meson8b-pwm-v2", "amlogic,meson8-pwm-v2";
				reg = <0x8550 0x10>;
				#pwm-cells = <0x03>;
				status = "disabled";
				clocks = <0x05 0x00 0x03 0x07 0x03 0x06>;
			};

			pwm@8650 {
				compatible = "amlogic,meson8b-pwm-v2", "amlogic,meson8-pwm-v2";
				reg = <0x8650 0x10>;
				#pwm-cells = <0x03>;
				status = "okay";
				clocks = <0x05 0x00 0x03 0x07 0x03 0x06>;
				pinctrl-0 = <0x09 0x0a>;
				pinctrl-names = "default";
				phandle = <0x34>;
			};

			adc@8680 {
				compatible = "amlogic,meson8b-saradc", "amlogic,meson-saradc";
				reg = <0x8680 0x34>;
				#io-channel-cells = <0x01>;
				interrupts = <0x00 0x49 0x01>;
				status = "disabled";
				clocks = <0x05 0x03 0x17>;
				clock-names = "clkin", "core";
				amlogic,hhi-sysctrl = <0x0b>;
				nvmem-cells = <0x0c>;
				nvmem-cell-names = "temperature_calib";
				vref-supply = <0x0d>;
				phandle = <0x02>;
			};

			serial@8700 {
				compatible = "amlogic,meson8b-uart";
				reg = <0x8700 0x18>;
				interrupts = <0x00 0x5d 0x01>;
				status = "disabled";
				clocks = <0x05 0x03 0x44 0x03 0x0a>;
				clock-names = "xtal", "pclk", "baud";
			};

			i2c@87c0 {
				compatible = "amlogic,meson6-i2c";
				reg = <0x87c0 0x20>;
				interrupts = <0x00 0x80 0x01>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				status = "disabled";
				clocks = <0x03 0x16>;
			};

			phy@8800 {
				compatible = "amlogic,meson8b-usb2-phy", "amlogic,meson-mx-usb2-phy";
				#phy-cells = <0x00>;
				reg = <0x8800 0x20>;
				gpio-controller;
				#gpio-cells = <0x02>;
				status = "okay";
				clocks = <0x03 0x37 0x03 0x32>;
				clock-names = "usb_general", "usb";
				resets = <0x08 0x22>;
				phandle = <0x17>;
			};

			phy@8820 {
				compatible = "amlogic,meson8b-usb2-phy", "amlogic,meson-mx-usb2-phy";
				#phy-cells = <0x00>;
				reg = <0x8820 0x20>;
				status = "okay";
				clocks = <0x03 0x37 0x03 0x33>;
				clock-names = "usb_general", "usb";
				resets = <0x08 0x22>;
				phandle = <0x18>;
			};

			mmc@8c20 {
				compatible = "amlogic,meson8b-sdio", "amlogic,meson-mx-sdio";
				reg = <0x8c20 0x20>;
				interrupts = <0x00 0x1c 0x01>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				status = "okay";
				clocks = <0x03 0x1e 0x03 0x0a>;
				clock-names = "core", "clkin";
				pinctrl-0 = <0x0e>;
				pinctrl-names = "default";

				slot@1 {
					compatible = "mmc-slot";
					reg = <0x01>;
					status = "okay";
					bus-width = <0x04>;
					no-sdio;
					cap-mmc-highspeed;
					cap-sd-highspeed;
					disable-wp;
					cd-gpios = <0x0f 0x35 0x01>;
					vmmc-supply = <0x10>;
				};
			};

			spi@8c80 {
				compatible = "amlogic,meson6-spifc";
				reg = <0x8c80 0x80>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				status = "disabled";
			};

			mmc@8e00 {
				compatible = "amlogic,meson8-sdhc", "amlogic,meson-mx-sdhc";
				reg = <0x8e00 0x42>;
				interrupts = <0x00 0x4e 0x01>;
				status = "disabled";
				clocks = <0x05 0x03 0x07 0x03 0x06 0x03 0x08 0x03 0x1b>;
				clock-names = "clkin0", "clkin1", "clkin2", "clkin3", "pclk";
			};

			interrupt-controller@9880 {
				compatible = "amlogic,meson8b-gpio-intc", "amlogic,meson-gpio-intc";
				reg = <0x9880 0x10>;
				interrupt-controller;
				#interrupt-cells = <0x02>;
				amlogic,channel-interrupts = <0x40 0x41 0x42 0x43 0x44 0x45 0x46 0x47>;
				status = "okay";
				phandle = <0x1c>;
			};

			watchdog@9900 {
				compatible = "amlogic,meson8b-wdt";
				reg = <0x9900 0x08>;
				interrupts = <0x00 0x00 0x01>;
			};

			timer@9940 {
				compatible = "amlogic,meson6-timer";
				reg = <0x9940 0x18>;
				interrupts = <0x00 0x0a 0x01 0x00 0x0b 0x01 0x00 0x06 0x01 0x00 0x1d 0x01>;
				clocks = <0x05 0x03 0x0a>;
				clock-names = "xtal", "pclk";
			};

			reset-controller@4404 {
				compatible = "amlogic,meson8b-reset";
				reg = <0x4404 0x9c>;
				#reset-cells = <0x01>;
				phandle = <0x08>;
			};

			analog-top@81a8 {
				compatible = "syscon";
				reg = <0x81a8 0x14>;
			};

			pwm@86c0 {
				compatible = "amlogic,meson8b-pwm-v2", "amlogic,meson8-pwm-v2";
				reg = <0x86c0 0x10>;
				clocks = <0x05 0x00 0x03 0x07 0x03 0x06>;
				#pwm-cells = <0x03>;
				status = "disabled";
			};

			clock-measure@8758 {
				compatible = "amlogic,meson8b-clk-measure";
				reg = <0x8758 0x1c>;
			};

			pinctrl@8030 {
				compatible = "amlogic,meson8b-cbus-pinctrl";
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				ranges = <0x00 0x8030 0x108>;
				phandle = <0x11>;

				bank@80 {
					reg = <0x80 0x28 0xb8 0x18 0xf0 0x18 0x00 0x38>;
					reg-names = "mux", "pull", "pull-enable", "gpio";
					gpio-controller;
					#gpio-cells = <0x02>;
					gpio-ranges = <0x11 0x00 0x00 0x53>;
					phandle = <0x0f>;
				};

				eth-rgmii {

					mux {
						groups = "eth_tx_clk", "eth_tx_en", "eth_txd1_0", "eth_txd0_0", "eth_rx_clk", "eth_rx_dv", "eth_rxd1", "eth_rxd0", "eth_mdio_en", "eth_mdc", "eth_ref_clk", "eth_txd2", "eth_txd3", "eth_rxd3", "eth_rxd2";
						function = "ethernet";
						bias-disable;
					};
				};

				eth-rmii {
					phandle = <0x1a>;

					mux {
						groups = "eth_tx_en", "eth_txd1_0", "eth_txd0_0", "eth_rx_clk", "eth_rx_dv", "eth_rxd1", "eth_rxd0", "eth_mdio_en", "eth_mdc";
						function = "ethernet";
						bias-disable;
					};
				};

				hdmi-hpd {
					phandle = <0x2b>;

					mux {
						groups = "hdmi_hpd";
						function = "hdmi";
						bias-disable;
					};
				};

				hdmi-i2c {
					phandle = <0x2c>;

					mux {
						groups = "hdmi_sda", "hdmi_scl";
						function = "hdmi";
						bias-disable;
					};
				};

				i2c-a {

					mux {
						groups = "i2c_sda_a", "i2c_sck_a";
						function = "i2c_a";
						bias-disable;
					};
				};

				sd-b {
					phandle = <0x0e>;

					mux {
						groups = "sd_d0_b", "sd_d1_b", "sd_d2_b", "sd_d3_b", "sd_clk_b", "sd_cmd_b";
						function = "sd_b";
						bias-disable;
					};
				};

				sdxc-c {

					mux {
						groups = "sdxc_d0_c", "sdxc_d13_c", "sdxc_d47_c", "sdxc_clk_c", "sdxc_cmd_c";
						function = "sdxc_c";
						bias-pull-up;
					};
				};

				pwm-c1 {
					phandle = <0x09>;

					mux {
						groups = "pwm_c1";
						function = "pwm_c";
						bias-disable;
					};
				};

				pwm-d {
					phandle = <0x0a>;

					mux {
						groups = "pwm_d";
						function = "pwm_d";
						bias-disable;
					};
				};

				uart-b0 {

					mux {
						groups = "uart_tx_b0", "uart_rx_b0";
						function = "uart_b";
						bias-pull-up;
					};
				};

				uart-b0-cts-rts {

					mux {
						groups = "uart_cts_b0", "uart_rts_b0";
						function = "uart_b";
						bias-disable;
					};
				};
			};
		};

		cache-controller@c4200000 {
			compatible = "arm,pl310-cache";
			reg = <0xc4200000 0x1000>;
			cache-unified;
			cache-level = <0x02>;
			arm,data-latency = <0x03 0x03 0x03>;
			arm,tag-latency = <0x02 0x02 0x02>;
			arm,filter-ranges = <0x100000 0xc0000000>;
			prefetch-data = <0x01>;
			prefetch-instr = <0x01>;
			arm,prefetch-offset = <0x07>;
			arm,double-linefill = <0x01>;
			arm,prefetch-drop = <0x01>;
			arm,shared-override;
			phandle = <0x1d>;
		};

		bus@c4300000 {
			compatible = "simple-bus";
			reg = <0xc4300000 0x10000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0xc4300000 0x10000>;

			interrupt-controller@1000 {
				compatible = "arm,cortex-a9-gic";
				reg = <0x1000 0x1000 0x100 0x100>;
				interrupt-controller;
				#interrupt-cells = <0x03>;
				phandle = <0x01>;
			};

			scu@0 {
				compatible = "arm,cortex-a5-scu";
				reg = <0x00 0x100>;
			};

			timer@200 {
				compatible = "arm,cortex-a5-global-timer";
				reg = <0x200 0x20>;
				interrupts = <0x01 0x0b 0xf01>;
				clocks = <0x03 0x7e>;
				status = "disabled";
			};

			timer@600 {
				compatible = "arm,cortex-a5-twd-timer";
				reg = <0x600 0x20>;
				interrupts = <0x01 0x0d 0xf01>;
				clocks = <0x03 0x7e>;
			};
		};

		bus@c8100000 {
			compatible = "simple-bus";
			reg = <0xc8100000 0x100000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0xc8100000 0x100000>;

			remoteproc@1c {
				compatible = "amlogic,meson8b-ao-arc", "amlogic,meson-mx-ao-arc";
				reg = <0x1c 0x08 0x38 0x08>;
				reg-names = "remap", "cpu";
				status = "okay";
				amlogic,secbus2 = <0x12>;
				sram = <0x13>;
				resets = <0x08 0x4d>;
				clocks = <0x03 0x59>;
				firmware-name = "zephyr.elf";
			};

			ir-receiver@480 {
				compatible = "amlogic,meson6-ir";
				reg = <0x480 0x20>;
				interrupts = <0x00 0x0f 0x01>;
				status = "disabled";
			};

			serial@4c0 {
				compatible = "amlogic,meson8b-uart", "amlogic,meson-ao-uart";
				reg = <0x4c0 0x18>;
				interrupts = <0x00 0x5a 0x01>;
				status = "okay";
				clocks = <0x05 0x03 0x0a 0x03 0x0a>;
				clock-names = "xtal", "pclk", "baud";
				pinctrl-0 = <0x14>;
				pinctrl-names = "default";
			};

			i2c@500 {
				compatible = "amlogic,meson6-i2c";
				reg = <0x500 0x20>;
				interrupts = <0x00 0x5c 0x01>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				status = "disabled";
				clocks = <0x03 0x0a>;
			};

			rtc@740 {
				compatible = "amlogic,meson8b-rtc";
				reg = <0x740 0x14>;
				interrupts = <0x00 0x48 0x01>;
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				status = "disabled";
				resets = <0x08 0x8a>;
			};

			pmu@e0 {
				compatible = "amlogic,meson8b-pmu", "syscon";
				reg = <0xe0 0x18>;
				phandle = <0x07>;
			};

			pinctrl@14 {
				compatible = "amlogic,meson8b-aobus-pinctrl";
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				ranges = <0x00 0x14 0x1c>;
				phandle = <0x15>;

				bank@0 {
					reg = <0x00 0x04 0x18 0x04 0x10 0x08>;
					reg-names = "mux", "pull", "gpio";
					gpio-controller;
					#gpio-cells = <0x02>;
					gpio-ranges = <0x15 0x00 0x00 0x10>;
				};

				hdmi-cec-ao {

					mux {
						groups = "hdmi_cec_1";
						function = "hdmi_cec";
						bias-pull-up;
					};
				};

				i2s-am-clk-out {

					mux {
						groups = "i2s_am_clk_out";
						function = "i2s";
						bias-disable;
					};
				};

				i2s-ao-clk-out {

					mux {
						groups = "i2s_ao_clk_out";
						function = "i2s";
						bias-disable;
					};
				};

				i2s-lr-clk-out {

					mux {
						groups = "i2s_lr_clk_out";
						function = "i2s";
						bias-disable;
					};
				};

				i2s-out-ch01 {

					mux {
						groups = "i2s_out_01";
						function = "i2s";
						bias-disable;
					};
				};

				spdif-out-1 {

					mux {
						groups = "spdif_out_1";
						function = "spdif_1";
						bias-disable;
					};
				};

				uart_ao_a {
					phandle = <0x14>;

					mux {
						groups = "uart_tx_ao_a", "uart_rx_ao_a";
						function = "uart_ao";
						bias-pull-up;
					};
				};

				remote {

					mux {
						groups = "remote_input";
						function = "remote";
						bias-disable;
					};
				};
			};

			cec@100 {
				compatible = "amlogic,meson-gx-ao-cec";
				reg = <0x100 0x14>;
				interrupts = <0x00 0x97 0x01>;
				hdmi-phandle = <0x16>;
				status = "disabled";
			};
		};

		usb@c9040000 {
			compatible = "amlogic,meson8b-usb", "snps,dwc2";
			reg = <0xc9040000 0x40000>;
			interrupts = <0x00 0x1e 0x04>;
			phys = <0x17>;
			phy-names = "usb2-phy";
			g-rx-fifo-size = <0x200>;
			g-np-tx-fifo-size = <0x1f4>;
			g-tx-fifo-size = <0x100 0xc0 0x80 0x80 0x80>;
			dr_mode = "host";
			status = "okay";
			clocks = <0x03 0x41>;
			clock-names = "otg";
		};

		usb@c90c0000 {
			compatible = "amlogic,meson8b-usb", "snps,dwc2";
			reg = <0xc90c0000 0x40000>;
			interrupts = <0x00 0x1f 0x04>;
			phys = <0x18>;
			phy-names = "usb2-phy";
			dr_mode = "host";
			status = "okay";
			clocks = <0x03 0x40>;
			clock-names = "otg";
		};

		ethernet@c9410000 {
			compatible = "amlogic,meson8b-dwmac", "snps,dwmac-3.70a", "snps,dwmac";
			reg = <0xc9410000 0x10000 0xc1108140 0x04>;
			interrupts = <0x00 0x08 0x04>;
			interrupt-names = "macirq";
			status = "okay";
			clocks = <0x03 0x24 0x03 0x5f 0x03 0x5f 0x03 0x05>;
			clock-names = "stmmaceth", "clkin0", "clkin1", "timing-adjustment";
			rx-fifo-depth = <0x1000>;
			tx-fifo-depth = <0x800>;
			resets = <0x08 0x2b>;
			reset-names = "stmmaceth";
			power-domains = <0x19 0x01>;
			pinctrl-0 = <0x1a>;
			pinctrl-names = "default";
			phy-handle = <0x1b>;
			phy-mode = "rmii";

			mdio {
				compatible = "snps,dwmac-mdio";
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				ethernet-phy@0 {
					reg = <0x00>;
					reset-assert-us = <0x2710>;
					reset-deassert-us = <0x2710>;
					reset-gpios = <0x0f 0x29 0x01>;
					icplus,select-interrupt;
					interrupt-parent = <0x1c>;
					interrupts = <0x11 0x08>;
					phandle = <0x1b>;
				};
			};
		};

		sram@d9000000 {
			compatible = "mmio-sram";
			reg = <0xd9000000 0x20000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0xd9000000 0x20000>;

			aoarc-sram@0 {
				compatible = "amlogic,meson8b-ao-arc-sram";
				reg = <0x00 0x8000>;
				pool;
				phandle = <0x13>;
			};

			smp-sram@1ff80 {
				compatible = "amlogic,meson8b-smp-sram";
				reg = <0x1ff80 0x08>;
			};
		};

		bootrom@d9040000 {
			compatible = "syscon";
			reg = <0xd9040000 0x10000>;
		};

		bus@da000000 {
			compatible = "simple-bus";
			reg = <0xda000000 0x6000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0xda000000 0x6000>;

			nvmem@0 {
				compatible = "amlogic,meson8b-efuse";
				reg = <0x00 0x2000>;
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				clocks = <0x03 0x3a>;
				clock-names = "core";
				status = "disabled";

				calib@1f4 {
					reg = <0x1f4 0x04>;
					phandle = <0x0c>;
				};

				calib@1f8 {
					reg = <0x1f8 0x02>;
					phandle = <0x04>;
				};
			};

			system-controller@4000 {
				compatible = "amlogic,meson8b-secbus2", "syscon";
				reg = <0x4000 0x2000>;
				phandle = <0x12>;
			};
		};
	};

	thermal-sensor {
		compatible = "generic-adc-thermal";
		#thermal-sensor-cells = <0x00>;
		io-channels = <0x02 0x08>;
		io-channel-names = "sensor-channel";
		phandle = <0x24>;
	};

	xtal-clk {
		compatible = "fixed-clock";
		clock-frequency = <0x16e3600>;
		clock-output-names = "xtal";
		#clock-cells = <0x00>;
		phandle = <0x05>;
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cpu@200 {
			device_type = "cpu";
			compatible = "arm,cortex-a5";
			next-level-cache = <0x1d>;
			reg = <0x200>;
			enable-method = "amlogic,meson8b-smp";
			resets = <0x03 0x03>;
			operating-points-v2 = <0x1e>;
			clocks = <0x03 0x0c>;
			#cooling-cells = <0x02>;
			cpu-supply = <0x1f>;
			phandle = <0x20>;
		};

		cpu@201 {
			device_type = "cpu";
			compatible = "arm,cortex-a5";
			next-level-cache = <0x1d>;
			reg = <0x201>;
			enable-method = "amlogic,meson8b-smp";
			resets = <0x03 0x04>;
			operating-points-v2 = <0x1e>;
			clocks = <0x03 0x0c>;
			#cooling-cells = <0x02>;
			phandle = <0x21>;
		};

		cpu@202 {
			device_type = "cpu";
			compatible = "arm,cortex-a5";
			next-level-cache = <0x1d>;
			reg = <0x202>;
			enable-method = "amlogic,meson8b-smp";
			resets = <0x03 0x05>;
			operating-points-v2 = <0x1e>;
			clocks = <0x03 0x0c>;
			#cooling-cells = <0x02>;
			phandle = <0x22>;
		};

		cpu@203 {
			device_type = "cpu";
			compatible = "arm,cortex-a5";
			next-level-cache = <0x1d>;
			reg = <0x203>;
			enable-method = "amlogic,meson8b-smp";
			resets = <0x03 0x06>;
			operating-points-v2 = <0x1e>;
			clocks = <0x03 0x0c>;
			#cooling-cells = <0x02>;
			phandle = <0x23>;
		};
	};

	opp-table {
		compatible = "operating-points-v2";
		opp-shared;
		phandle = <0x1e>;

		opp-96000000 {
			opp-hz = <0x00 0x5b8d800>;
			opp-microvolt = <0xd1f60>;
		};

		opp-192000000 {
			opp-hz = <0x00 0xb71b000>;
			opp-microvolt = <0xd1f60>;
		};

		opp-312000000 {
			opp-hz = <0x00 0x1298be00>;
			opp-microvolt = <0xd1f60>;
		};

		opp-408000000 {
			opp-hz = <0x00 0x18519600>;
			opp-microvolt = <0xd1f60>;
		};

		opp-504000000 {
			opp-hz = <0x00 0x1e0a6e00>;
			opp-microvolt = <0xd1f60>;
		};

		opp-600000000 {
			opp-hz = <0x00 0x23c34600>;
			opp-microvolt = <0xd1f60>;
		};

		opp-720000000 {
			opp-hz = <0x00 0x2aea5400>;
			opp-microvolt = <0xd1f60>;
		};

		opp-816000000 {
			opp-hz = <0x00 0x30a32c00>;
			opp-microvolt = <0xdbba0>;
		};

		opp-1008000000 {
			opp-hz = <0x00 0x3c14dc00>;
			opp-microvolt = <0x116520>;
		};

		opp-1200000000 {
			opp-hz = <0x00 0x47868c00>;
			opp-microvolt = <0x116520>;
		};

		opp-1320000000 {
			opp-hz = <0x00 0x4ead9a00>;
			opp-microvolt = <0x116520>;
		};

		opp-1488000000 {
			opp-hz = <0x00 0x58b11400>;
			opp-microvolt = <0x116520>;
		};

		opp-1536000000 {
			opp-hz = <0x00 0x5b8d8000>;
			opp-microvolt = <0x116520>;
		};
	};

	opp-table-gpu {
		compatible = "operating-points-v2";
		phandle = <0x28>;

		opp-255000000 {
			opp-hz = <0x00 0xf32fdc0>;
			opp-microvolt = <0x10c8e0>;
		};

		opp-364285714 {
			opp-hz = <0x00 0x15b68f12>;
			opp-microvolt = <0x10c8e0>;
		};

		opp-425000000 {
			opp-hz = <0x00 0x1954fc40>;
			opp-microvolt = <0x10c8e0>;
		};

		opp-510000000 {
			opp-hz = <0x00 0x1e65fb80>;
			opp-microvolt = <0x10c8e0>;
		};

		opp-637500000 {
			opp-hz = <0x00 0x25ff7a60>;
			opp-microvolt = <0x10c8e0>;
			turbo-mode;
		};
	};

	pmu {
		compatible = "arm,cortex-a5-pmu";
		interrupts = <0x00 0x89 0x04 0x00 0x8a 0x04 0x00 0x99 0x04 0x00 0x9a 0x04>;
		interrupt-affinity = <0x20 0x21 0x22 0x23>;
	};

	reserved-memory {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;

		hwrom@0 {
			reg = <0x00 0x200000>;
			no-map;
		};

		secmon@4e00000 {
			reg = <0x4e00000 0x9b00000>;
			no-map;
		};
	};

	thermal-zones {

		soc-thermal {
			polling-delay-passive = <0xfa>;
			polling-delay = <0x3e8>;
			thermal-sensors = <0x24>;

			cooling-maps {

				map0 {
					trip = <0x25>;
					cooling-device = <0x20 0xffffffff 0xffffffff 0x21 0xffffffff 0xffffffff 0x22 0xffffffff 0xffffffff 0x23 0xffffffff 0xffffffff 0x26 0xffffffff 0xffffffff>;
				};

				map1 {
					trip = <0x27>;
					cooling-device = <0x20 0xffffffff 0xffffffff 0x21 0xffffffff 0xffffffff 0x22 0xffffffff 0xffffffff 0x23 0xffffffff 0xffffffff 0x26 0xffffffff 0xffffffff>;
				};
			};

			trips {

				soc-passive {
					temperature = <0x13880>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x25>;
				};

				soc-hot {
					temperature = <0x15f90>;
					hysteresis = <0x7d0>;
					type = "hot";
					phandle = <0x27>;
				};

				soc-critical {
					temperature = <0x1adb0>;
					hysteresis = <0x7d0>;
					type = "critical";
				};
			};
		};
	};

	bus@c8000000 {
		compatible = "simple-bus";
		reg = <0xc8000000 0x8000>;
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges = <0x00 0xc8000000 0x8000>;

		clock-controller@400 {
			compatible = "amlogic,meson8b-ddr-clkc";
			reg = <0x400 0x20>;
			clocks = <0x05>;
			clock-names = "xtal";
			#clock-cells = <0x01>;
			phandle = <0x06>;
		};

		bus@6000 {
			compatible = "simple-bus";
			reg = <0x6000 0x400>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0x6000 0x400>;

			video-lut@48 {
				compatible = "amlogic,meson8b-canvas", "amlogic,canvas";
				reg = <0x48 0x14>;
				phandle = <0x2f>;
			};
		};
	};

	bus@d0000000 {
		compatible = "simple-bus";
		reg = <0xd0000000 0x200000>;
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges = <0x00 0xd0000000 0x200000>;

		gpu@c0000 {
			compatible = "amlogic,meson8b-mali", "arm,mali-450";
			reg = <0xc0000 0x40000>;
			interrupts = <0x00 0xa0 0x04 0x00 0xa1 0x04 0x00 0xa2 0x04 0x00 0xa3 0x04 0x00 0xa4 0x04 0x00 0xa5 0x04 0x00 0xa6 0x04 0x00 0xa7 0x04>;
			interrupt-names = "gp", "gpmmu", "pp", "pmu", "pp0", "ppmmu0", "pp1", "ppmmu1";
			resets = <0x08 0x4e>;
			clocks = <0x03 0x0a 0x03 0x0b>;
			clock-names = "bus", "core";
			operating-points-v2 = <0x28>;
			#cooling-cells = <0x02>;
			mali-supply = <0x29>;
			phandle = <0x26>;
		};

		hdmi-tx@42000 {
			compatible = "amlogic,meson8b-hdmi-tx";
			reg = <0x42000 0x0c>;
			interrupts = <0x00 0x39 0x01>;
			phys = <0x2a>;
			phy-names = "hdmi";
			clocks = <0x03 0x3f 0x03 0xae>;
			clock-names = "pclk", "sys";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			#sound-dai-cells = <0x01>;
			sound-name-prefix = "HDMITX";
			status = "okay";
			pinctrl-0 = <0x2b 0x2c>;
			pinctrl-names = "default";
			phandle = <0x16>;

			port@0 {
				reg = <0x00>;

				endpoint {
					remote-endpoint = <0x2d>;
					phandle = <0x31>;
				};
			};

			port@1 {
				reg = <0x01>;

				endpoint {
					remote-endpoint = <0x2e>;
					phandle = <0x32>;
				};
			};
		};

		vpu@100000 {
			compatible = "amlogic,meson8b-vpu";
			reg = <0x100000 0x10000>;
			reg-names = "vpu";
			interrupts = <0x00 0x03 0x01>;
			amlogic,canvas = <0x2f>;
			assigned-clocks = <0x03 0x8a 0x03 0x95>;
			assigned-clock-parents = <0x03 0x89 0x03 0x89>;
			clocks = <0x03 0x46 0x03 0x3e 0x03 0x4d 0x03 0x84 0x03 0xa7 0x03 0xa3 0x03 0xa5 0x03 0xa1 0x03 0xa9 0x03 0xab>;
			clock-names = "vpu_intr", "hdmi_intr_sync", "venci_int", "tmds", "hdmi_tx_pixel", "cts_encp", "cts_enci", "cts_enct", "cts_encl", "cts_vdac0";
			resets = <0x03 0x0f 0x03 0x0e 0x03 0x0d 0x03 0x0c>;
			reset-names = "vid_pll_pre", "vid_pll_post", "vid_pll_soft_pre", "vid_pll_soft_post";
			phys = <0x30>;
			phy-names = "cvbs-dac";
			power-domains = <0x19 0x00>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			#sound-dai-cells = <0x00>;
			sound-name-prefix = "HDMITX";

			port@0 {
				reg = <0x00>;
			};

			port@1 {
				reg = <0x01>;

				endpoint {
					remote-endpoint = <0x31>;
					phandle = <0x2d>;
				};
			};
		};
	};

	aliases {
		serial0 = "/soc/bus@c8100000/serial@4c0";
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0x40000000 0x40000000>;
	};

	hdmi-connector {
		compatible = "hdmi-connector";
		type = "a";

		port {

			endpoint {
				remote-endpoint = <0x32>;
				phandle = <0x2e>;
			};
		};
	};

	regulator-vcck {
		compatible = "pwm-regulator";
		regulator-name = "VCCK";
		regulator-min-microvolt = <0xd1f60>;
		regulator-max-microvolt = <0x116520>;
		pwm-supply = <0x33>;
		pwms = <0x34 0x00 0x47c 0x00>;
		pwm-dutycycle-range = <0x64 0x00>;
		regulator-boot-on;
		regulator-always-on;
		phandle = <0x1f>;
	};

	sound {
		compatible = "amlogic,gx-sound-card";
		model = "M8B-MXQ";
		clocks = <0x03 0x5d 0x03 0x5e>;
		assigned-clocks = <0x03 0x5d 0x03 0x5e>;
		assigned-clock-rates = <0x11940000 0x10266000>;

		dai-link-0 {
			sound-dai = <0x35 0x00 0x00>;
		};

		dai-link-1 {
			sound-dai = <0x35 0x00 0x02>;
			dai-format = "i2s";
			mclk-fs = <0x100>;

			codec-0 {
				sound-dai = <0x35 0x01 0x00>;
			};
		};

		dai-link-2 {
			sound-dai = <0x35 0x01 0x02>;

			codec-0 {
				sound-dai = <0x16 0x00>;
			};
		};
	};

	regulator-vcc1v8 {
		compatible = "regulator-fixed";
		regulator-name = "VCC1V8";
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		vin-supply = <0x10>;
		phandle = <0x0d>;
	};

	regulator-vcc3v3 {
		compatible = "regulator-fixed";
		regulator-name = "VCC3V3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		vin-supply = <0x33>;
		phandle = <0x10>;
	};

	regulator-vcc5v {
		compatible = "regulator-fixed";
		regulator-name = "VCC5V";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		regulator-boot-on;
		regulator-always-on;
		phandle = <0x33>;
	};

	regulator-vddee {
		compatible = "pwm-regulator";
		regulator-name = "VDDEE";
		regulator-min-microvolt = <0xd1f60>;
		regulator-max-microvolt = <0x116520>;
		pwm-supply = <0x33>;
		pwms = <0x34 0x01 0x47c 0x00>;
		pwm-dutycycle-range = <0x64 0x00>;
		regulator-boot-on;
		regulator-always-on;
		phandle = <0x29>;
	};
};
