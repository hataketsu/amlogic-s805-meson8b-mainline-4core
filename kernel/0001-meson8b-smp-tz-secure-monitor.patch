+/*
+ * RE helper: dump the secure-monitor / secure DRAM region via the secure-read
+ * SMC (r0=2). Lets us disassemble the monitor (normally unreadable from the
+ * non-secure world) to recover this firmware's real secondary-CPU boot SMC.
+ * Window: 0x04f00000..0x05200000 (3 MiB) covering the monitor + secure OS head.
+ */
+#define MESON_SECMON_BASE	0x04f00000u
+#define MESON_SECMON_LEN	0x00300000u
+
+static ssize_t meson_secmon_read(struct file *f, char __user *ubuf,
+				 size_t len, loff_t *ppos)
+{
+	loff_t pos = *ppos;
+	size_t done = 0;
+
+	if (pos < 0 || pos >= MESON_SECMON_LEN)
+		return 0;
+	if (pos + len > MESON_SECMON_LEN)
+		len = MESON_SECMON_LEN - pos;
+
+	while (done < len) {
+		u32 w = meson_tz_smc(2, MESON_SECMON_BASE + (u32)(pos + done), 0, 0);
+		size_t n = min(sizeof(w), len - done);
+
+		if (copy_to_user(ubuf + done, &w, n))
+			return -EFAULT;
+		done += n;
+	}
+	*ppos += done;
+	return done;
+}
+
+static const struct proc_ops meson_secmon_pops = {
+	.proc_read	= meson_secmon_read,
+	.proc_lseek	= default_llseek,
+};
+
+static int __init meson_secmon_init(void)
+{
+	proc_create("meson_secmon", 0400, NULL, &meson_secmon_pops);
+	return 0;
+}
+late_initcall(meson_secmon_init);
