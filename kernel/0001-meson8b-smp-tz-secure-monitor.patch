+/*
+ * On secure (TEE) Meson8b boxes the SMP holding-pen SRAM is locked to the
+ * secure world; non-secure access aborts. When meson_tz_sram_phys is set,
+ * route SRAM reads/writes through the secure monitor (smc r0=2 read,
+ * r0=3 write). The AO/PMU power regs and SCU are NOT locked (verified) so
+ * the rest of the meson8b bringup flow is reused unchanged.
+ */
+static u32 meson_tz_smc(u32 r0, u32 r1, u32 r2, u32 r3);
+static phys_addr_t meson_tz_sram_phys;
+
+static u32 meson_sram_readl(u32 off)
+{
+	if (meson_tz_sram_phys)
+		return meson_tz_smc(2, meson_tz_sram_phys + off, 0, 0);
+	return readl(sram_base + off);
+}
+
+static void meson_sram_writel(u32 val, u32 off)
+{
+	if (meson_tz_sram_phys)
+		meson_tz_smc(3, meson_tz_sram_phys + off, val, 0);
+	else
+		writel(val, sram_base + off);
+}
